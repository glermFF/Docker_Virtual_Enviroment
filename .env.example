# Docker Virtual Environment - Arquivo de Configuração
# Copie este arquivo para .env e customize conforme necessário

# === Elasticsearch ===
ES_JAVA_OPTS=-Xms512m -Xmx512m
ES_CLUSTER_NAME=es-cluster
ES_NODE_NAME=es01

# === Kibana ===
KIBANA_PORT=5601
KIBANA_ELASTICSEARCH_URL=http://elasticsearch:9200

# === MariaDB (DVWA) ===
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=dvwa
MYSQL_USER=dvwa
MYSQL_PASSWORD=dvwa

# === VPS Target (DVWA) ===
VPS_PORT=8080
VPS_HOST=127.0.0.1

# === Malware Analysis ===
MALWARE_SAMPLES_PATH=${HOME}/amostras
MALWARE_OUTPUT_PATH=./malware/resultados

# === Pentesting ===
PENTEST_TARGET=vps-target
PENTEST_REPORTS_PATH=./pentesting/reports

# === Traffic Host ===
TRAFFIC_MODE=normal
TRAFFIC_TARGET_URL=http://vps-target/login.php
TRAFFIC_AUDIT_URL=http://kibana:5601/api/status
TRAFFIC_DURATION=180
TRAFFIC_RPS=5
TRAFFIC_BURST_SIZE=10
TRAFFIC_REPORTS_PATH=./relatorios/traffic-host

# === Docker Compose Profiles ===
# Opções: audit, vps, vulnerable, malware, pentest, all
# Separar múltiplos com vírgula: audit,vps,malware
COMPOSE_PROFILES=all
